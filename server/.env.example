# Environment
NODE_ENV=development

# Server
PORT=5000

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/taxi_booking?schema=public"

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars-long-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-long-change-this

# JWT Expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000
